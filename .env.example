# Obsidian vault location (default: ~/KitchenOS/vault)
# Set explicitly to avoid ambiguity when running as a LaunchAgent
KITCHENOS_VAULT=/Users/chaseeasterling/KitchenOS/vault

# YouTube Data API Key
# Get this from: https://console.developers.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenAI API Key for Whisper transcription
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here