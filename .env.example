# Obsidian vault location, resolved via lib/paths.py (vault_root() etc.)
# Always set this explicitly — the lib/paths.py fallback default is dead code,
# not documentation, and running without this set is ambiguous under a LaunchAgent.
KITCHENOS_VAULT=/path/to/your/vault

# Claude (Anthropic) API key — load-bearing for receipt parsing and meal
# suggestions when configured; Ollama is the local fallback.
# Get this from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube Data API Key
# Get this from: https://console.developers.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenAI API Key for Whisper transcription
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# USDA FoodData Central API key — primary nutrition source for the gram-based
# nutrition engine. Free, instant: https://fdc.nal.usda.gov/api-key-signup.html
# Falls back to the shared, rate-limited DEMO_KEY if unset.
USDA_FDC_API_KEY=your_usda_fdc_api_key_here

# Instagram Reel ingestion (extract_recipe.py with an instagram.com/reel/ URL).
# Anonymous yt-dlp works for many public reels, but Instagram throttles repeated
# fetches. To authenticate, set ONE of the following (browser cookies preferred):
#   INSTAGRAM_COOKIES_FROM_BROWSER=chrome   # or safari, firefox, edge, brave
#   INSTAGRAM_COOKIES_FILE=/path/to/instagram_cookies.txt
INSTAGRAM_COOKIES_FROM_BROWSER=
INSTAGRAM_COOKIES_FILE=

# legacy/deprecated (engine uses USDA + Open Food Facts)
# Nutritionix — formerly the primary nutrition lookup source; superseded by
# lib/nutrition_engine.py's USDA FoodData Central + Open Food Facts pipeline.
NUTRITIONIX_APP_ID=your_nutritionix_app_id_here
NUTRITIONIX_API_KEY=your_nutritionix_api_key_here

# Gmail account for receipt email ingest (App Password, not your login password —
# generate one at https://myaccount.google.com/apppasswords)
GMAIL_ADDRESS=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Second Gmail account — CSA produce newsletter ingest (separate inbox from the
# receipt-ingest account above)
GMAIL_ADDRESS_2=your_second_gmail_address@gmail.com
GMAIL_APP_PASSWORD_2=your_second_gmail_app_password_here

# Bearer token gating remote (non-localhost) calls to the Siri-facing API routes.
# See docs/API.md for the exact gated-route list.
KITCHENOS_API_TOKEN=your_kitchenos_api_token_here