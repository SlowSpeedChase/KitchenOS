<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Sandbox is intentionally OFF on macOS: the optional local extraction path
         spawns the project's Python interpreter (Process). The primary extraction
         path goes through the API server (POST /extract) and does not need this. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
